# LOC (local) environment — non-secret defaults, git-tracked.
# Loaded via `node --env-file=.env.loc` in the dev script.
# Put real secrets in .env.local (gitignored); keep keys disjoint from this file
# because Next.js does not override variables already set in process.env.
APP_ENV=LOC
NEXT_PUBLIC_API_MOCKING=enabled
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_URL=http://localhost:3000/api
