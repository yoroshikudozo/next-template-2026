# Reference for all environment variables. Copy secrets into .env.local.
#
# Environment strategy:
#   .env.loc   LOC (local) non-secret config — git-tracked, loaded by `npm run dev`
#   .env.stg   STG non-secret config — git-tracked, loaded by `npm run build:stg`
#   .env.prod  PROD non-secret config — git-tracked, loaded by `npm run build:prod`
#   .env.local secrets / local overrides — gitignored, auto-loaded by Next.js
#
# Each env file is loaded via Node's native `--env-file`. Next.js does NOT
# override variables already in process.env, so keep secret keys (.env.local)
# disjoint from the non-secret per-env files.

# Which deployment tier this build/run targets (LOC | STG | PROD).
APP_ENV=

# "enabled" turns on MSW request mocking for both the server (Server Components,
# Route Handlers) and the browser (Client Components). Empty = real APIs.
NEXT_PUBLIC_API_MOCKING=

# Public base URL of the API (exposed to the browser).
NEXT_PUBLIC_API_URL=

# Server-only base URL of the API.
API_URL=
